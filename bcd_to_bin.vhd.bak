--------------------------------------------------------------------------------
-- Conversor BCD a Binario - logica combinacional
-- Entrada:  bcd(11..8)=centenas, bcd(7..4)=decenas, bcd(3..0)=unidades
-- Salida:   bin = centenas*100 + decenas*10 + unidades  (0 a 999)
--------------------------------------------------------------------------------
library ieee;
use ieee.std_logic_1164.all;
use ieee.std_logic_unsigned.all;

entity bcd_to_bin is
    port(
        bcd : in  std_logic_vector(11 downto 0);
        bin : out std_logic_vector(9 downto 0)
    );
end entity;

architecture rtl of bcd_to_bin is
    signal c    : std_logic_vector(9 downto 0);
    signal d    : std_logic_vector(9 downto 0);
    signal u    : std_logic_vector(9 downto 0);
    signal c100 : std_logic_vector(9 downto 0);
    signal d10  : std_logic_vector(9 downto 0);
begin
    -- Extender digitos BCD a 10 bits con ceros
    c <= "000000" & bcd(11 downto 8);
    d <= "000000" & bcd( 7 downto 4);
    u <= "000000" & bcd( 3 downto 0);

    -- c * 100 = c*64 + c*32 + c*4
    -- Se implementa con desplazamientos (concatenacion con ceros)
    -- c max = 9, c*100 max = 900, cabe en 10 bits (max 1023)
    c100 <= (c(3 downto 0) & "000000")   -- c * 64  (bits 9..6 del resultado)
          + (c(4 downto 0) & "00000")    -- c * 32  (bits 9..5 del resultado)
          + (c(7 downto 0) & "00");      -- c *  4  (bits 9..2 del resultado)

    -- d * 10 = d*8 + d*2
    -- d max = 9, d*10 max = 90, cabe en 10 bits
    d10  <= (d(6 downto 0) & "000")      -- d *  8  (bits 9..3 del resultado)
          + (d(8 downto 0) & '0');       -- d *  2  (bits 9..1 del resultado)

    bin <= c100 + d10 + u;
end rtl;